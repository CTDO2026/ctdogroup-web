---
// Importar componentes de logotipos vectoriales SVG si se requiere
---
<header class="sticky top-0 z-50 bg-white border-b border-slate-100 shadow-sm h-20 flex items-center">
  <div class="max-w-7xl mx-auto px-4 w-full flex justify-between items-center">
    
    <div class="flex-shrink-0">
      <a href="/" class="text-xl font-extrabold text-corporativo-textoOscuro tracking-tight flex items-center gap-1">
        CTDO<span class="text-brand-ctdo font-medium">GROUP</span>
      </a>
    </div>

    <nav class="hidden md:flex space-x-8 items-center h-full">
      <a href="/" class="text-sm font-medium text-corporativo-textoMutado hover:text-brand-ctdo">Inicio</a>

      <div class="relative group py-4">
        <button class="flex items-center gap-1 text-sm font-medium text-corporativo-textoMutado group-hover:text-brand-ctdo">
          Consultoría
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-14 left-0 hidden group-hover:block w-80 bg-white border border-slate-100 rounded-xl shadow-xl p-4">
          <div class="space-y-3">
            <a href="/consultoria/fortalecimiento-empresarial" class="block p-2 rounded-lg hover:bg-slate-50">
              <p class="text-sm font-semibold text-corporativo-textoOscuro">Fortalecimiento Empresarial</p>
            </a>
            <a href="/consultoria/estrategica-y-financiera" class="block p-2 rounded-lg hover:bg-slate-50">
              <p class="text-sm font-semibold text-corporativo-textoOscuro">Estratégica y Financiera</p>
              <p class="text-xs text-corporativo-textoMutado">CX, Coherencia Organizacional y Liderazgo</p>
            </a>
            <a href="/consultoria/ambiental" class="block p-2 rounded-lg bg-emerald-50/50 hover:bg-emerald-50 border border-transparent hover:border-brand-stgreenly/20">
              <p class="text-sm font-bold text-brand-stgreenly">Consultoría Ambiental (STGreenly)</p>
            </a>
          </div>
        </div>
      </div>

      <div class="relative group py-4">
        <button class="flex items-center gap-1 text-sm font-medium text-corporativo-textoMutado group-hover:text-brand-ctdo">
          Negocios Internacionales
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-14 left-0 hidden group-hover:block w-72 bg-white border border-slate-100 rounded-xl shadow-xl p-4">
          <div class="space-y-2">
            <a href="/negocios-internacionales/nacional" class="block p-2 rounded-lg hover:bg-slate-50 text-sm font-semibold text-corporativo-textoOscuro">Mercado Nacional</a>
            <a href="/negocios-internacionales/internacional" class="block p-2 rounded-lg hover:bg-slate-50 text-sm font-semibold text-corporativo-textoOscuro">Mercado Internacional</a>
            <a href="https://colombiatodo.com" target="_blank" class="block mt-2 p-2 bg-orange-50 text-center rounded-lg text-xs font-bold text-brand-colombiatodo hover:bg-orange-100">Visitar Colombiatodo.com ↗</a>
          </div>
        </div>
      </div>

      <a href="/seguros" class="text-sm font-medium text-corporativo-textoMutado hover:text-brand-ctdo">Seguros</a>
      <a href="/grupos-electrogenos" class="text-sm font-medium text-corporativo-textoMutado hover:text-brand-ctdo">Grupos Electrógenos</a>

      <div class="relative group py-4">
        <button class="flex items-center gap-1 text-sm font-medium text-brand-desarrollo bg-indigo-50/70 px-3 py-1.5 rounded-lg">
          Desarrollo Web & IT
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-14 right-0 hidden group-hover:block w-64 bg-white border border-slate-100 rounded-xl shadow-xl p-4">
          <div class="space-y-2">
            <a href="/desarrollo-web/diseno-grafico" class="block p-2 rounded-lg hover:bg-slate-50 text-sm font-semibold text-corporativo-textoOscuro">Diseño Gráfico & UI/UX</a>
            <a href="/desarrollo-web/frontend-backend" class="block p-2 rounded-lg hover:bg-slate-50 text-sm font-semibold text-corporativo-textoOscuro">Frontend & Backend</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="hidden md:block">
      <a href="#contacto" class="bg-brand-ctdo hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-all shadow-sm">Contacto Central</a>
    </div>
  </div>
</header>