---
import Navbar from './Navbar.astro';
const { title, description = "Ecosistema empresarial de soluciones corporativas - CTDO GROUP" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} | CTDO GROUP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body class="bg-corporativo-fondoClaro text-corporativo-textoOscuro min-h-screen flex flex-col justify-between antialiased">
    <Navbar />
    <main class="flex-grow">
      <slot />
    </main>
    <footer class="bg-slate-900 text-slate-400 py-8 border-t border-slate-800 text-center text-sm">
      <p>&copy; {new Date().getFullYear()} CTDO GROUP. Todos los derechos reservados.</p>
      <p class="text-xs text-slate-500 mt-2">Transformación Digital e Infraestructura impulsada por <span class="text-brand-desarrollo font-medium">CTDO Desarrollo Web & IT</span></p>
    </footer>
  </body>
</html>