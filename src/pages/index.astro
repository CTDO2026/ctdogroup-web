    </div>

  </div>

  <footer>
    <div class="wrapper">
      <p>&copy; {new Date().getFullYear()} CTDO GROUP &nbsp;·&nbsp; <a href="mailto:gerencia@colombiatodo.com">gerencia@colombiatodo.com</a></p>
      <p style="margin-top:6px;">Desde Colombia para Latinoamérica y Estados Unidos</p>
    </div>
  </footer>

</body>
</html>
