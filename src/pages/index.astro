      <!-- KSEG Seguros -->
      <div
        class="brand-card"
        style="--accent:#0284c7; --accent-dim:rgba(2,132,199,.12); --accent-border:rgba(2,132,199,.22); --accent-text:#38bdf8;"
      >
        <div class="card-icon">🛡️</div>
        <div class="card-tag">Agencia de Seguros</div>
        <div class="card-title">KSEG — Agencia de Seguros</div>
        <div class="card-desc">Protección integral para personas, empresas y patrimonios. Seguros y gestión del riesgo con acompañamiento especializado y permanente.</div>
