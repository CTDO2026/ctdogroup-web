---
// Página de Expectativa - CTDO GROUP
// Próximamente: www.ctdogroup.com
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CTDO GROUP — Próximamente</title>
  <meta name="description" content="Ecosistema empresarial que integra consultoría, comercio internacional, sostenibilidad, seguros, energía y transformación digital para Latinoamérica y Estados Unidos." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #060a12;
      color: #e2e8f0;
      min-height: 100vh;
    }

    /* ── Fondo animado ── */
    .bg-grid {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }
    .bg-glow {
      position: fixed;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 500px;
      background: radial-gradient(ellipse at center, rgba(30,64,175,.18) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── Layout ── */
    .wrapper {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ── Header ── */
    header {
      padding: 60px 0 0;
      text-align: center;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(30,64,175,.15);
      border: 1px solid rgba(30,64,175,.4);
      color: #93c5fd;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 999px;
      margin-bottom: 28px;
    }
    .badge-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #60a5fa;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: .5; transform: scale(.8); }
    }

    .logo {
      font-size: clamp(2.8rem, 7vw, 5rem);
      font-weight: 900;
      letter-spacing: -.03em;
      color: #f8fafc;
      line-height: 1;
    }
    .logo span { color: #3b82f6; font-weight: 400; }

    .tagline {
      margin-top: 16px;
      font-size: clamp(.95rem, 2vw, 1.2rem);
      color: #64748b;
      font-weight: 400;
      letter-spacing: .01em;
    }
    .tagline strong { color: #94a3b8; font-weight: 600; }

    .hero-desc {
      max-width: 640px;
      margin: 20px auto 0;
      font-size: .95rem;
      color: #475569;
      line-height: 1.7;
    }

    /* ── Divider ── */
    .divider {
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, #1e40af, #6366f1);
      border-radius: 2px;
      margin: 48px auto;
    }

    /* ── Sección de marcas ── */
    .section-label {
      text-align: center;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: #475569;
      margin-bottom: 36px;
    }

    .brands-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      padding-bottom: 80px;
    }

    /* ── Tarjeta de marca ── */
    .brand-card {
      position: relative;
      background: rgba(15,23,42,.7);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 20px;
      padding: 28px;
      transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
    }
    .brand-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--accent);
      opacity: .7;
      border-radius: 20px 20px 0 0;
    }
    .brand-card.is-link:hover {
      transform: translateY(-4px);
      border-color: rgba(255,255,255,.15);
      box-shadow: 0 20px 60px rgba(0,0,0,.4), 0 0 0 1px var(--accent-dim);
    }

    .card-icon {
      width: 44px; height: 44px;
      border-radius: 12px;
      background: var(--accent-dim);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      margin-bottom: 16px;
      border: 1px solid var(--accent-border);
    }

    .card-tag {
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--accent-text);
      margin-bottom: 6px;
    }

    .card-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #f1f5f9;
      line-height: 1.3;
      margin-bottom: 8px;
    }

    .card-desc {
      font-size: .83rem;
      color: #475569;
      line-height: 1.6;
      flex-grow: 1;
    }

    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 16px;
      font-size: .75rem;
      font-weight: 600;
      color: var(--accent-text);
      opacity: .7;
      transition: opacity .2s;
    }
    .brand-card.is-link:hover .card-link { opacity: 1; }

    .card-link-soon {
      margin-top: 16px;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #1e293b;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.06);
      display: inline-block;
      padding: 4px 10px;
      border-radius: 6px;
      align-self: flex-start;
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid rgba(255,255,255,.06);
      padding: 32px 0;
      text-align: center;
    }
    footer p { font-size: .8rem; color: #334155; }
    footer a { color: #3b82f6; text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .brands-grid { grid-template-columns: 1fr; }
      header { padding-top: 40px; }
    }
  </style>
</head>
<body>

  <div class="bg-grid"></div>
